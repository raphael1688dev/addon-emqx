#!/command/with-contenv bashio
# shellcheck shell=bash
# ==============================================================================
# Home Assistant Community Add-on: EMQX
# Configures EMQX
# ==============================================================================
mkdir -p \
  /data/emqx/data \
  /data/emqx/etc \
  /data/emqx/plugins

#!/usr/bin/with-contenv bash
set -e

echo "Patching EMQX config.yaml for Basic Auth..."

# 檢查是否已安裝 yq
if ! command -v yq &> /dev/null; then
  echo "yq not found, detecting architecture..."

  ARCH=$(uname -m)
  case "$ARCH" in
    x86_64)
      YQ_URL="https://github.com/mikefarah/yq/releases/download/v4.40.5/yq_linux_amd64"
      ;;
    aarch64)
      YQ_URL="https://github.com/mikefarah/yq/releases/download/v4.40.5/yq_linux_arm64"
      ;;
    armv7l)
      YQ_URL="https://github.com/mikefarah/yq/releases/download/v4.40.5/yq_linux_arm"
      ;;
    *)
      echo "Unsupported architecture: $ARCH"
      exit 1
      ;;
  esac

  echo "Downloading yq for $ARCH..."
  curl -sL "$YQ_URL" -o /usr/bin/yq
  chmod +x /usr/bin/yq
fi

# 執行 YAML patch
yq eval '
  .dashboard.auth.method = "basic" |
  .dashboard.auth.basic.username = "admin" |
  .dashboard.auth.basic.password = "secret123"
' -i /opt/emqx/etc/config.yaml

echo "EMQX config.yaml patched successfully."
