#!/usr/bin/with-contenv bash
set -e

echo "Patching EMQX config.yaml for Basic Auth..."

# 安裝 yq（若未內建）
if ! command -v yq &> /dev/null; then
  echo "Installing yq..."
  curl -sL https://github.com/mikefarah/yq/releases/download/v4.40.5/yq_linux_amd64 -o /usr/bin/yq
  chmod +x /usr/bin/yq
fi

# 修改 dashboard.auth 區段
yq eval '
  .dashboard.auth.method = "basic" |
  .dashboard.auth.basic.username = "admin" |
  .dashboard.auth.basic.password = "public"
' -i /opt/emqx/etc/config.yaml
